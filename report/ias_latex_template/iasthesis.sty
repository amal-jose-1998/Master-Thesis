% iasthesis ... simplifying thesis writing in LaTeX complying with the style of IAS, University of Stuttgart
% This class does the styling for you (together with a komascript class).
%
% It handles the following:
% - Proper input and font encoding (Just type, don't care about the LaTeX compiler you use or how to type German umlauts)
% - Fonts with ligatures and kerning (Tex Gyre fonts are used, part of every LaTeX installation, text is nice to read)
% - Bibliography styling for biblatex (declare your bibliography file and you are ready to go)
% - Provide command for title page (\makeIAStitle) and declaration of originality ( \declarationOfOriginality)
% - Loads packages "biblatex" and "graphics"
%
% Package dependencies:
%	- ifthen, ifpdf, ifxetex, ifluatex, iflang, kvoptions ... Options handling
%	- microtype ... font kerning
%	- [just pdflatex] fontenc, inputenc ... handle encodings
%	- tgheros ... sans serif font for headings
%	- [just luatex and xetex] fontspec ... font loading
%	- mathpazo, tgpagella, textcomp 	 ... math, serif and unicode fonts
%	- csquotes ... handling quotes correctly with biblatex
%	- biblatex ... bibliography
%	- graphicx ... loading logo image for the titlepage
%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{iasthesis}[2023-02-03 v0.0.1 Basic styling for a student thesis written at IAS, University of Stuttgart.]
\providecommand{\iasthesis}{iasthesis v0.0.1}

\RequirePackage{ifthen}
\RequirePackage{ifpdf}
\RequirePackage{ifxetex}
\RequirePackage{ifluatex}
\usepackage{iflang}

% ********************************************************************
% Template commands (mainly used for title page)
% ********************************************************************
\providecommand{\runningauthor}[1]{\gdef\iast@runningauthor{#1}}
\providecommand{\major}[1]{\gdef\iast@major{#1}}

\providecommand{\thesisno}[1]{\gdef\iast@thesisno{#1}}

\providecommand{\supervisor}[1]{\gdef\iast@supervisor{#1}}
\providecommand{\professor}[1]{\gdef\iast@professor{#1}}
\providecommand{\extsupervisor}[1]{\gdef\iast@extsupervisor{#1}}
\providecommand{\extcompany}[1]{\gdef\iast@extcompany{#1}}
\providecommand{\confidentialthesis}[0]{\gdef\iast@confidentialthesis{}}


% ********************************************************************
% Package options
% ********************************************************************
\RequirePackage{kvoptions}
\SetupKeyvalOptions{family=iast, prefix=iast@}


\DeclareStringOption[bachelor]{type}[]

% Parse the given options
\ProcessKeyvalOptions{iast}

% ********************************************************************
% Style
% ********************************************************************

% micro-typographic extensions to have a better readable text
\RequirePackage{microtype}

\ifthenelse{\boolean{xetex}\OR\boolean{luatex}}{
	\relax
}{
	% pdflatex needs to know the font and file formats
	\PassOptionsToPackage{T1}{fontenc} % T2A for cyrillics
	\RequirePackage{fontenc}

	\PassOptionsToPackage{utf8}{inputenc} % directly support utf8 characters, as ä,ö,ü,Ü,ß
	\RequirePackage{inputenc}

}


% Disable single lines at the start of a paragraph (Schusterjungen)
\clubpenalty = 10000
% Disable single lines at the end of a paragraph (Hurenkinder)
\widowpenalty = 10000
\displaywidowpenalty = 10000 % formulas

% load fonts with ligatures and proper kerning

\PassOptionsToPackage{osf,sc}{mathpazo}%
\RequirePackage{mathpazo} % Palatino with real small caps and old style figures
\usepackage{tgheros}
\linespread{1.05} % a bit more for Palatino
\PassOptionsToPackage{scaled=0.85}{DejaVuSansMon}%
\RequirePackage{tgpagella}% bera monospace font
\RequirePackage{textcomp}% declare missing symbols

\ifthenelse{\boolean{xetex}\OR\boolean{luatex}}
   { % use fontspec and OpenType fonts with utf8 engines
	\RequirePackage{fontspec}
	\defaultfontfeatures{Ligatures=TeX}
	\setsansfont{Tex Gyre Heros}
	\setmainfont[Numbers=OldStyle]{TeX Gyre Pagella}
	\setmonofont[Scale=0.85]{DejaVu Sans Mono}
   }{
	\relax
   }



% Bibliography
\PassOptionsToPackage{%
  backend=biber,%
  backref=false,%
  giveninits=true,%
  autocite=inline,%
  sorting=none,% in order of occurence. Other option: nyt (name year title)
  sortcites=true,%
  mincitenames=1,%
  maxcitenames=2,%
  maxbibnames=10,%
  doi=false,%
  isbn=false,%
  url=false,%
  natbib=true,
}{biblatex}

\ifthenelse{\equal{\iast@type}{diss}}{% TRUE
  \PassOptionsToPackage{%
    style=authoryear,%
  }{biblatex}
}{% FALSE
  \PassOptionsToPackage{%
    style=ieee,%
  }{biblatex}
}%

\RequirePackage{csquotes}
\RequirePackage{biblatex}
\setcounter{biburlnumpenalty}{100}

\RequirePackage{graphicx}

% ********************************************************************
% Style
% ********************************************************************

% detect German language, assume English otherwise (https://tex.stackexchange.com/a/174206)
\newcommand*{\IfLangGerman}{%
% The order can be optimized by putting more often used names first.
\IfLanguageName{ngerman}\@firstoftwo{%
\IfLanguageName{german}\@firstoftwo\@secondoftwo}%
}%


% Process variables
\def\iast@thesisType{\texttt{type}-Option invalid}
\def\iast@aimedDegree{}

\ifthenelse{\equal{\iast@type}{bachelor}}{
	\def\iast@thesisType{\IfLangGerman{Bachelorarbeit}{Bachelor Thesis}}
%	\def\iast@aimedDegree{B.\,Sc.}
}{}
\ifthenelse{\equal{\iast@type}{master}}{
	\def\iast@thesisType{\IfLangGerman{Masterarbeit}{Master Thesis}}
%	\def\iast@aimedDegree{M.\,Sc.}
}{}
\ifthenelse{\equal{\iast@type}{study}}{
	\def\iast@thesisType{\IfLangGerman{Studienarbeit}{Study Paper}}
%	\def\iast@aimedDegree{M.\,Sc.}
}{}
\ifthenelse{\equal{\iast@type}{diss}}{
	\def\iast@thesisType{Dissertation}
%	\def\iast@aimedDegree{Dr.-Ing.}
}{}
\ifthenelse{\equal{\iast@type}{bachelorproject}}{
	\def\iast@thesisType{\IfLangGerman{Bachelor-Projektarbeit}{Bachelor Project}}
%	\def\iast@aimedDegree{B.\,Sc.}
}{}


